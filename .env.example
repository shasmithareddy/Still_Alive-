# ============================================================================
# Backend/Signaling Server Configuration
# ============================================================================
# For local dev: http://localhost:3001 or http://<your-local-ip>:3001
# For production: your deployed backend URL (e.g., https://backend.example.com)
# Render production example: https://your-app.onrender.com
VITE_BACKEND_URL=http://localhost:3001

# Server URL (used by CLI bridge, defaults to VITE_BACKEND_URL behavior)
# For CLI clients: set to your backend URL
SERVER_URL=http://localhost:3001

# PeerJS Server Configuration (optional)
# If using a public/custom PeerJS server, set these values
# Leave empty to use default PeerJS cloud
# VITE_PEER_HOST=your-peer-server.example.com
# VITE_PEER_PORT=443
# VITE_PEER_PATH=/peerjs
# VITE_PEER_SECURE=true

# For local development with a PeerJS server running on port 9000:
# VITE_PEER_HOST=localhost
# VITE_PEER_PORT=9000
# VITE_PEER_PATH=/peerjs
# VITE_PEER_SECURE=false
